# Network. Keep the backend on loopback and terminate TLS at a reverse proxy.
HOST=127.0.0.1
PORT=4180
# Docker host binding; keep loopback and publish through a TLS reverse proxy.
APP_BIND_ADDRESS=127.0.0.1
# Canonical browser origin. Optional in paper mode; mandatory and HTTPS in
# private-live. It must be an exact origin (no path/query/credentials).
# PUBLIC_ORIGIN=https://trade.example.com
# Cross-origin browser allowlist. Same-origin needs no entry. An explicit empty
# value disables the development localhost defaults.
# ALLOWED_ORIGINS=

# Account authentication. Registration creates a pending account; an admin
# activates it in the UI. `legacy` exists only for tests/explicit demo installs.
AUTH_MODE=database
AUTH_REGISTRATION_ENABLED=1

# Hard per-user control-plane quotas. Existing rows above a lowered limit stay
# readable/editable/stoppable; only new creates or starts are rejected (HTTP 429).
TRADING_MAX_ACCOUNTS_PER_USER=8
TRADING_MAX_BOTS_PER_USER=24
TRADING_MAX_RUNNING_PAPER_BOTS_PER_USER=4
TRADING_MAX_RUNNING_LIVE_BOTS_PER_USER=2

# Authentication abuse controls. Login failures are limited independently by
# client IP and normalized login; registration counts every attempt, including
# success. Argon2id uses about 64 MiB per active operation, so raise hash
# concurrency only after measuring memory and event-loop/API latency.
AUTH_LOGIN_RATE_WINDOW_MS=900000
AUTH_LOGIN_RATE_BLOCK_MS=900000
AUTH_LOGIN_IP_MAX_FAILURES=30
AUTH_LOGIN_IDENTITY_MAX_FAILURES=10
AUTH_REGISTER_RATE_WINDOW_MS=3600000
AUTH_REGISTER_RATE_BLOCK_MS=3600000
AUTH_REGISTER_IP_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_MAX_ENTRIES=4096
AUTH_PASSWORD_HASH_CONCURRENCY=2
AUTH_PASSWORD_HASH_QUEUE=32
API_RATE_REFILL_PER_SECOND=20
API_RATE_BURST=240
API_RATE_MAX_BUCKETS=4096

# Dedicated PostgreSQL identity/workspace/job database. The Compose service is
# published on loopback only and does not touch any other PostgreSQL instance.
POSTGRES_HOST_PORT=55434
PGHOST=127.0.0.1
PGPORT=55434
PGDATABASE=saltanatbotv2
PGUSER=saltanatbotv2
# Host installation: absolute path. Compose: relative secret path is accepted
# through POSTGRES_PASSWORD_FILE and mounted internally at /run/secrets/...
POSTGRES_PASSWORD_FILE=.secrets/postgres_password
PGPOOL_MAX=12

# HTTPS reverse proxy prerequisites for a future private-live deployment: trust
# loopback, exact proxy IPs, or a pool of at most 16 addresses (IPv4 /28 or IPv6
# /124 and narrower), then mark cookies Secure. Broad named ranges and
# TRUST_PROXY=true are rejected.
# TRUST_PROXY=loopback
# COOKIE_SECURE=1

# Reserved unsafe escape hatch. The supported public-http-paper and private-live
# boundaries both reject it when true; leave it unset/false.
# ALLOW_INSECURE_TRADING_MUTATIONS=0

# Execution boundary. This fail-closed profile is the default and is required
# for every public-HTTP deployment: public data, research, backtests and paper
# robots work; exchange keys and every signed/private exchange request do not.
RUNTIME_PROFILE=public-http-paper

# Enable only after HTTPS is deployed and all prerequisites above are set:
# RUNTIME_PROFILE=private-live

# Deprecated compatibility alias for public-http-paper.
# DEMO_MODE=1

# Optional direct-host path for the bounded, append-only multi-leg paper
# journal. Compose operators should leave this unset so the default stays in
# the persistent /app/backend/data named volume, unless they add another
# explicit persistent mount and backup policy.
# PAPER_MULTI_LEG_DB_PATH=/var/lib/saltanatbotv2/arbitrage-paper-multi-leg.sqlite

# Optional public/read-only continuous route discovery. The browser can observe
# this operator allowlist but cannot change it. Each row must match a currently
# verified /api/instruments ID and the exact central reviewed identity catalog;
# environment values cannot invent an equivalence. Never place credentials here.
# Prefer the committed, reviewable file form in long-running deployments. Set
# exactly one of FILE or JSON. The path must be absolute and the file regular,
# non-symlinked, valid UTF-8 and at most 64 KiB.
# Compose path (the repository config directory is mounted read-only):
# ARBITRAGE_CONTINUOUS_ROUTES_FILE=/app/config/continuous-routes.research.json
# Direct-host path example:
# ARBITRAGE_CONTINUOUS_ROUTES_FILE=/absolute/path/to/config/continuous-routes.research.json
# ARBITRAGE_CONTINUOUS_ROUTES_JSON=[{"instrumentId":"okx:spot:BTC-USDT","economicAssetId":"crypto:bitcoin","takerFeeBps":10,"economicIdentity":{"status":"reviewed","source":"docs/VENUE_CAPABILITIES.md official venue references and normalized instrument fixtures","version":"2026-07-14.v1","asOf":1783987200000,"validUntil":1791763200000}}]
