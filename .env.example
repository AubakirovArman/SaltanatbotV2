# Network. Keep the backend on loopback and terminate TLS at a reverse proxy.
HOST=127.0.0.1
PORT=4180

# Set a long random value in production. Never commit the real token.
AUTH_TOKEN=replace-with-a-long-random-secret

# HTTPS reverse proxy example: trust only a loopback proxy and mark cookies Secure.
# TRUST_PROXY=loopback
# COOKIE_SECURE=1

# Development escape hatch only. Never enable on a public or production host.
# ALLOW_INSECURE_TRADING_MUTATIONS=1

# Public demo: disables key storage and all live trading.
# DEMO_MODE=1

# Optional path for the bounded, append-only multi-leg paper journal. The
# default is backend/data/arbitrage-paper-multi-leg.sqlite.
# PAPER_MULTI_LEG_DB_PATH=/var/lib/saltanatbotv2/arbitrage-paper-multi-leg.sqlite

# Optional public/read-only continuous route discovery. The browser can observe
# this operator allowlist but cannot change it. Each row must match a currently
# verified /api/instruments ID and the exact central reviewed identity catalog;
# environment values cannot invent an equivalence. Never place credentials here.
# Prefer the committed, reviewable file form in long-running deployments. Set
# exactly one of FILE or JSON. The path must be absolute and the file regular,
# non-symlinked, valid UTF-8 and at most 64 KiB.
# ARBITRAGE_CONTINUOUS_ROUTES_FILE=/absolute/path/to/config/continuous-routes.research.json
# ARBITRAGE_CONTINUOUS_ROUTES_JSON=[{"instrumentId":"okx:spot:BTC-USDT","economicAssetId":"crypto:bitcoin","takerFeeBps":10,"economicIdentity":{"status":"reviewed","source":"docs/VENUE_CAPABILITIES.md official venue references and normalized instrument fixtures","version":"2026-07-14.v1","asOf":1783987200000,"validUntil":1791763200000}}]
