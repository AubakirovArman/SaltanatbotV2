# ── Dependencies ──────────────────────────────────────────────
node_modules/
.npm/

# ── Build output ──────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Secrets & runtime data (NEVER COMMIT) ─────────────────────
