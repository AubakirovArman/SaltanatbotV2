# database (which holds encrypted exchange API keys) under data/.
backend/data/
data/
*.secret
*.db
*.sqlite
*.sqlite3
.env
.env.*
!.env.example

# ── Logs & temp ───────────────────────────────────────────────
*.log
logs/
runtime-logs/
tmp/
.cache/
test-results/
playwright-report/
blob-report/

# ── Internal dev artifacts (kept local, not published) ────────
audits/
IMPROVEMENT_PLAN.md

# ── Claude Code (agent worktrees, local session state) ────────
.claude/

# ── Editor / OS ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
