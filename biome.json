{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "ignore": [
      "**/dist/**",
      "**/node_modules/**",
      "**/*.d.ts",
      "backend/data/**",
      "audits/**",
      "package-lock.json",
      "**/*.json"
    ]
  },
  "organizeImports": {
    "enabled": false
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 320,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "none",
      "semicolons": "always",
      "arrowParentheses": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noAriaHiddenOnFocusable": "off",
        "noAutofocus": "off",
        "useSemanticElements": "off",
        "useKeyWithClickEvents": "off",
        "useFocusableInteractive": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useNumberNamespace": "off",
        "useImportType": "off",
        "useTemplate": "off",
        "noUnusedTemplateLiteral": "off",
        "useConst": "off"
      },
      "complexity": {
        "noForEach": "off",
        "noUselessSwitchCase": "off",
        "useOptionalChain": "off",
        "useLiteralKeys": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "off",
        "noThenProperty": "off"
      }
    }
  }
}
