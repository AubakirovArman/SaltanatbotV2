{
  "name": "saltanatbotv2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,green \"PORT=4181 npm --workspace backend run dev\" \"npm --workspace frontend run dev -- --host 0.0.0.0\"",
    "build": "npm --workspaces --if-present run build",
    "start": "npm --workspace backend run start",
    "check": "npm --workspaces --if-present run check",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:testnet": "node scripts/exchange-testnet-smoke.mjs",
    "release:package": "node scripts/package-release.mjs",
    "docs:check": "node scripts/check-docs.mjs && node scripts/generate-pine-compatibility.mjs --check && node scripts/generate-reference-docs.mjs --check",
    "docs:generate": "node scripts/generate-pine-compatibility.mjs && node scripts/generate-reference-docs.mjs",
    "docs:generate:check": "node scripts/generate-pine-compatibility.mjs --check && node scripts/generate-reference-docs.mjs --check",
    "pine:compat": "node scripts/generate-pine-compatibility.mjs",
    "pine:compat:check": "node scripts/generate-pine-compatibility.mjs --check",
    "lint": "biome check --formatter-enabled=false --assists-enabled=false .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@biomejs/biome": "^1.9.4",
    "concurrently": "^9.2.1",
    "vitest": "^4.1.10"
  }
}
