{
  "name": "@saltanatbotv2/strategy-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "scripts": {
    "build": "tsc ta.ts --target ES2022 --module NodeNext --moduleResolution NodeNext --skipLibCheck --declaration --outDir .",
    "check": "tsc ta.ts --target ES2022 --module NodeNext --moduleResolution NodeNext --skipLibCheck --noEmit && node ../../scripts/check-strategy-core-ta.mjs"
  },
  "dependencies": {
    "@saltanatbotv2/contracts": "0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
